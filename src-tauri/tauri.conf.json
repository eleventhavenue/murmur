{
  "$schema": "https://raw.githubusercontent.com/nicedayzhu/tauri-release/v2/tooling/cli/schema.json",
  "productName": "Murmur",
  "version": "0.1.1",
  "identifier": "com.murmur.tts",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "popup",
        "title": "Murmur",
        "width": 480,
        "height": 68,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "center": true,
        "resizable": false
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false,
      "tooltip": "Murmur — Read Aloud"
    },
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/eleventhavenue/murmur/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg1RDQ1RkVDOTMyMDY3QkQKUldTOVp5Q1Q3Ri9VaGFFS29SaUhaNUNUS2ttcG5uRW56Tm1XS2pqRGFLckVLTlVlb3F2c1Roc2oK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "binaries/murmur-tts/**/*"
    ]
  }
}
